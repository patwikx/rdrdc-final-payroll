// ============================================================================
// MATERIAL REQUEST DOMAIN - Employee Portal Requisition + Configurable Approval
// ============================================================================

enum MaterialRequestSeries {
  PO
  JO
  OTHERS
}

enum MaterialRequestType {
  ITEM
  SERVICE
}

enum MaterialRequestStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CANCELLED
}

enum MaterialRequestProcessingStatus {
  PENDING_PURCHASER
  IN_PROGRESS
  COMPLETED
}

enum MaterialRequestPostingStatus {
  PENDING_POSTING
  POSTED
}

enum MaterialRequestStepStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
}

enum MaterialRequestItemSource {
  MANUAL
  CATALOG
}

enum PurchaseRequestStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CANCELLED
}

enum PurchaseRequestItemSource {
  MANUAL
  CATALOG
}

enum PurchaseOrderStatus {
  DRAFT
  OPEN
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CLOSED
  CANCELLED
}

model DepartmentMaterialRequestApprovalFlow {
  id String @id @default(uuid())

  companyId    String
  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departmentId String     @unique
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  requiredSteps Int     @default(1)
  isActive      Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  createdBy   User?    @relation("DepartmentMaterialRequestApprovalFlowCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?    @relation("DepartmentMaterialRequestApprovalFlowUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  steps DepartmentMaterialRequestApprovalFlowStep[]

  @@index([companyId])
  @@index([isActive])
}

model DepartmentMaterialRequestApprovalFlowStep {
  id String @id @default(uuid())

  flowId String
  flow   DepartmentMaterialRequestApprovalFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  stepNumber Int
  stepName   String?

  approverUserId String
  approverUser   User   @relation("DepartmentMaterialRequestApprovalFlowStepApprover", fields: [approverUserId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([flowId, stepNumber, approverUserId])
  @@index([flowId, stepNumber])
  @@index([approverUserId])
}

model MaterialRequest {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  requestNumber String
  series        MaterialRequestSeries
  requestType   MaterialRequestType
  status        MaterialRequestStatus @default(DRAFT)

  requesterEmployeeId             String
  requesterEmployee               Employee @relation("MaterialRequestRequesterEmployee", fields: [requesterEmployeeId], references: [id], onDelete: Restrict)
  requesterUserId                 String
  requesterUser                   User     @relation("MaterialRequestRequesterUser", fields: [requesterUserId], references: [id], onDelete: Restrict)
  selectedInitialApproverUserId   String?
  selectedInitialApproverUser     User?    @relation("MaterialRequestSelectedInitialApproverUser", fields: [selectedInitialApproverUserId], references: [id], onDelete: SetNull)
  selectedStepTwoApproverUserId   String?
  selectedStepTwoApproverUser     User?    @relation("MaterialRequestSelectedStepTwoApproverUser", fields: [selectedStepTwoApproverUserId], references: [id], onDelete: SetNull)
  selectedStepThreeApproverUserId String?
  selectedStepThreeApproverUser   User?    @relation("MaterialRequestSelectedStepThreeApproverUser", fields: [selectedStepThreeApproverUserId], references: [id], onDelete: SetNull)
  selectedStepFourApproverUserId  String?
  selectedStepFourApproverUser    User?    @relation("MaterialRequestSelectedStepFourApproverUser", fields: [selectedStepFourApproverUserId], references: [id], onDelete: SetNull)

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  datePrepared DateTime @db.Date
  dateRequired DateTime @db.Date

  chargeTo   String?
  bldgCode   String?
  purpose    String? @db.Text
  remarks    String? @db.Text
  deliverTo  String?
  isStoreUse Boolean @default(false)

  freight    Decimal @default(0) @db.Decimal(12, 2)
  discount   Decimal @default(0) @db.Decimal(12, 2)
  subTotal   Decimal @default(0) @db.Decimal(14, 2)
  grandTotal Decimal @default(0) @db.Decimal(14, 2)

  requiredSteps Int
  currentStep   Int?

  submittedAt                   DateTime?
  approvedAt                    DateTime?
  rejectedAt                    DateTime?
  cancelledAt                   DateTime?
  processingStatus              MaterialRequestProcessingStatus?
  processingStartedAt           DateTime?
  processingCompletedAt         DateTime?
  processingRemarks             String?                          @db.Text
  processedByUserId             String?
  processedByUser               User?                            @relation("MaterialRequestProcessedByUser", fields: [processedByUserId], references: [id], onDelete: SetNull)
  requesterAcknowledgedAt       DateTime?
  requesterAcknowledgedByUserId String?
  requesterAcknowledgedByUser   User?                            @relation("MaterialRequestRequesterAcknowledgedByUser", fields: [requesterAcknowledgedByUserId], references: [id], onDelete: SetNull)
  requiresReceiptAcknowledgment Boolean                          @default(true)
  postingStatus                 MaterialRequestPostingStatus?
  postingReference              String?
  postingRemarks                String?                          @db.Text
  postedAt                      DateTime?
  postedByUserId                String?
  postedByUser                  User?                            @relation("MaterialRequestPostedByUser", fields: [postedByUserId], references: [id], onDelete: SetNull)

  finalDecisionByUserId String?
  finalDecisionByUser   User?   @relation("MaterialRequestFinalDecisionByUser", fields: [finalDecisionByUserId], references: [id], onDelete: SetNull)
  finalDecisionRemarks  String? @db.Text

  cancellationReason String? @db.Text
  cancelledByUserId  String?
  cancelledByUser    User?   @relation("MaterialRequestCancelledByUser", fields: [cancelledByUserId], references: [id], onDelete: SetNull)

  // Migration trace
  legacySourceSystem   String?
  legacyRecordId       String?
  legacyBusinessUnitId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  steps            MaterialRequestApprovalStep[]
  items            MaterialRequestItem[]
  serveBatches     MaterialRequestServeBatch[]
  postings         MaterialRequestPosting[]
  receivingReports MaterialRequestReceivingReport[]

  @@unique([companyId, requestNumber])
  @@unique([companyId, legacySourceSystem, legacyRecordId])
  @@index([companyId, status])
  @@index([departmentId])
  @@index([requesterEmployeeId])
  @@index([selectedInitialApproverUserId])
  @@index([selectedStepTwoApproverUserId])
  @@index([selectedStepThreeApproverUserId])
  @@index([selectedStepFourApproverUserId])
  @@index([processedByUserId])
  @@index([requesterAcknowledgedByUserId])
  @@index([requesterAcknowledgedAt])
  @@index([postedByUserId])
  @@index([processingStatus])
  @@index([postingStatus])
  @@index([companyId, status, processingStatus])
  @@index([companyId, status, processingStatus, requesterAcknowledgedAt])
  @@index([companyId, status, postingStatus])
  @@index([submittedAt])
}

model MaterialRequestApprovalStep {
  id String @id @default(uuid())

  materialRequestId String
  materialRequest   MaterialRequest @relation(fields: [materialRequestId], references: [id], onDelete: Cascade)

  stepNumber Int
  stepName   String?

  approverUserId String
  approverUser   User   @relation("MaterialRequestApprovalStepApprover", fields: [approverUserId], references: [id], onDelete: Restrict)

  status        MaterialRequestStepStatus @default(PENDING)
  actedAt       DateTime?
  actedByUserId String?
  actedByUser   User?                     @relation("MaterialRequestApprovalStepActor", fields: [actedByUserId], references: [id], onDelete: SetNull)
  remarks       String?                   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([materialRequestId, stepNumber, approverUserId])
  @@index([approverUserId, status])
  @@index([materialRequestId, stepNumber, status])
  @@index([materialRequestId, status])
}

model MaterialRequestItem {
  id String @id @default(uuid())

  materialRequestId String
  materialRequest   MaterialRequest @relation(fields: [materialRequestId], references: [id], onDelete: Cascade)

  lineNumber Int
  source     MaterialRequestItemSource @default(MANUAL)

  itemCode    String?
  description String
  uom         String
  quantity    Decimal  @db.Decimal(12, 3)
  unitPrice   Decimal? @db.Decimal(12, 2)
  lineTotal   Decimal? @db.Decimal(14, 2)
  remarks     String?  @db.Text

  legacyItemId String?

  createdAt            DateTime                             @default(now())
  updatedAt            DateTime                             @updatedAt
  serveBatchItems      MaterialRequestServeBatchItem[]
  receivingReportItems MaterialRequestReceivingReportItem[]

  @@unique([materialRequestId, lineNumber])
  @@unique([materialRequestId, itemCode])
  @@index([materialRequestId])
  @@index([itemCode])
}

model ProcurementItemCategory {
  id String @id @default(uuid())

  code        String
  name        String
  description String? @db.Text
  isActive    Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  createdBy   User?    @relation("ProcurementItemCategoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?    @relation("ProcurementItemCategoryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  items ProcurementItem[]

  @@unique([code])
  @@unique([name])
  @@index([isActive])
}

model ProcurementItem {
  id String @id @default(uuid())

  categoryId String
  category   ProcurementItemCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  code        String
  name        String
  description String?  @db.Text
  uom         String
  unitPrice   Decimal? @db.Decimal(12, 2)
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  createdBy   User?    @relation("ProcurementItemCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?    @relation("ProcurementItemUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  purchaseRequestItems PurchaseRequestItem[]

  @@unique([code])
  @@index([categoryId, isActive])
}

model ExternalRequesterProfile {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("ExternalRequesterProfileUser", fields: [userId], references: [id], onDelete: Cascade)

  requesterCode String
  agencyName    String?
  branchId      String?
  branch        Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseRequests PurchaseRequest[] @relation("PurchaseRequestRequesterExternalProfile")

  @@unique([companyId, userId])
  @@unique([companyId, requesterCode])
  @@index([companyId, isActive])
  @@index([userId])
  @@index([branchId])
}

model PurchaseRequest {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  requestNumber String
  series        MaterialRequestSeries @default(PO)
  requestType   MaterialRequestType   @default(ITEM)
  status        PurchaseRequestStatus @default(DRAFT)

  requesterEmployeeId        String?
  requesterEmployee          Employee?                 @relation("PurchaseRequestRequesterEmployee", fields: [requesterEmployeeId], references: [id], onDelete: Restrict)
  requesterExternalProfileId String?
  requesterExternalProfile   ExternalRequesterProfile? @relation("PurchaseRequestRequesterExternalProfile", fields: [requesterExternalProfileId], references: [id], onDelete: SetNull)
  requesterUserId            String
  requesterUser              User     @relation("PurchaseRequestRequesterUser", fields: [requesterUserId], references: [id], onDelete: Restrict)
  selectedInitialApproverUserId   String?
  selectedInitialApproverUser     User?    @relation("PurchaseRequestSelectedInitialApproverUser", fields: [selectedInitialApproverUserId], references: [id], onDelete: SetNull)
  selectedStepTwoApproverUserId   String?
  selectedStepTwoApproverUser     User?    @relation("PurchaseRequestSelectedStepTwoApproverUser", fields: [selectedStepTwoApproverUserId], references: [id], onDelete: SetNull)
  selectedStepThreeApproverUserId String?
  selectedStepThreeApproverUser   User?    @relation("PurchaseRequestSelectedStepThreeApproverUser", fields: [selectedStepThreeApproverUserId], references: [id], onDelete: SetNull)
  selectedStepFourApproverUserId  String?
  selectedStepFourApproverUser    User?    @relation("PurchaseRequestSelectedStepFourApproverUser", fields: [selectedStepFourApproverUserId], references: [id], onDelete: SetNull)

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  datePrepared DateTime @db.Date
  dateRequired DateTime @db.Date
  requesterBranchName String?

  purpose    String? @db.Text
  remarks    String? @db.Text
  deliverTo  String?
  isStoreUse Boolean @default(false)

  freight    Decimal @default(0) @db.Decimal(12, 2)
  discount   Decimal @default(0) @db.Decimal(12, 2)
  subTotal   Decimal @default(0) @db.Decimal(14, 2)
  grandTotal Decimal @default(0) @db.Decimal(14, 2)
  approvalCycle Int               @default(0)
  requiredSteps Int               @default(0)
  currentStep   Int?

  submittedAt DateTime?
  approvedAt  DateTime?
  rejectedAt  DateTime?
  cancelledAt DateTime?

  finalDecisionByUserId String?
  finalDecisionByUser   User?   @relation("PurchaseRequestFinalDecisionByUser", fields: [finalDecisionByUserId], references: [id], onDelete: SetNull)
  finalDecisionRemarks  String? @db.Text
  sentBackAt            DateTime?
  sentBackReason        String? @db.Text
  sentBackByUserId      String?
  sentBackByUser        User?   @relation("PurchaseRequestSentBackByUser", fields: [sentBackByUserId], references: [id], onDelete: SetNull)
  sentBackAcknowledgedAt DateTime?
  cancellationReason    String? @db.Text
  cancelledByUserId     String?
  cancelledByUser       User?   @relation("PurchaseRequestCancelledByUser", fields: [cancelledByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items          PurchaseRequestItem[]
  steps          PurchaseRequestApprovalStep[]
  purchaseOrders PurchaseOrder[]

  @@unique([companyId, requestNumber])
  @@index([companyId, status])
  @@index([departmentId])
  @@index([requesterEmployeeId])
  @@index([requesterExternalProfileId])
  @@index([selectedInitialApproverUserId])
  @@index([selectedStepTwoApproverUserId])
  @@index([selectedStepThreeApproverUserId])
  @@index([selectedStepFourApproverUserId])
  @@index([series])
  @@index([requestType])
  @@index([currentStep])
  @@index([approvalCycle])
  @@index([finalDecisionByUserId])
  @@index([sentBackByUserId])
  @@index([cancelledByUserId])
  @@index([submittedAt])
}

model PurchaseRequestApprovalStep {
  id String @id @default(uuid())

  purchaseRequestId String
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  approvalCycle     Int

  stepNumber Int
  stepName   String?

  approverUserId String
  approverUser   User   @relation("PurchaseRequestApprovalStepApprover", fields: [approverUserId], references: [id], onDelete: Restrict)

  status        MaterialRequestStepStatus @default(PENDING)
  actedAt       DateTime?
  actedByUserId String?
  actedByUser   User?                     @relation("PurchaseRequestApprovalStepActor", fields: [actedByUserId], references: [id], onDelete: SetNull)
  remarks       String?                   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([purchaseRequestId, approvalCycle, stepNumber, approverUserId])
  @@index([approverUserId, status])
  @@index([purchaseRequestId, approvalCycle, stepNumber, status], map: "PurchaseRequestApprovalStep_pr_cycle_step_status_idx")
  @@index([purchaseRequestId, approvalCycle, status], map: "PurchaseRequestApprovalStep_pr_cycle_status_idx")
}

model PurchaseRequestItem {
  id String @id @default(uuid())

  purchaseRequestId String
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)

  procurementItemId String?
  procurementItem   ProcurementItem? @relation(fields: [procurementItemId], references: [id], onDelete: SetNull)

  lineNumber Int
  source     PurchaseRequestItemSource @default(MANUAL)

  itemCode    String?
  description String
  uom         String
  quantity    Decimal  @db.Decimal(12, 3)
  unitPrice   Decimal? @db.Decimal(12, 2)
  lineTotal   Decimal? @db.Decimal(14, 2)
  remarks     String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrderLines PurchaseOrderLine[]

  @@unique([purchaseRequestId, lineNumber])
  @@unique([purchaseRequestId, itemCode])
  @@index([purchaseRequestId])
  @@index([procurementItemId])
}

model PurchaseOrder {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  sourcePurchaseRequestId String
  sourcePurchaseRequest   PurchaseRequest @relation(fields: [sourcePurchaseRequestId], references: [id], onDelete: Restrict)

  poNumber String
  status   PurchaseOrderStatus @default(DRAFT)

  supplierName         String
  paymentTerms         String   @default("COD")
  remarks              String?   @db.Text
  purchaseOrderDate    DateTime  @db.Date
  expectedDeliveryDate DateTime? @db.Date

  applyVat   Boolean @default(false)
  vatAmount  Decimal @default(0) @db.Decimal(14, 2)
  discount   Decimal @default(0) @db.Decimal(14, 2)
  freight    Decimal @default(0) @db.Decimal(14, 2)
  subtotal   Decimal @default(0) @db.Decimal(14, 2)
  grandTotal Decimal @default(0) @db.Decimal(14, 2)

  createdByUserId String
  createdByUser   User   @relation("PurchaseOrderCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Restrict)

  issuedAt    DateTime?
  closedAt    DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines         PurchaseOrderLine[]
  goodsReceipts PurchaseOrderGoodsReceipt[]

  @@unique([companyId, poNumber])
  @@index([companyId, status])
  @@index([sourcePurchaseRequestId])
  @@index([createdByUserId])
}

model PurchaseOrderLine {
  id String @id @default(uuid())

  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  sourcePurchaseRequestItemId String
  sourcePurchaseRequestItem   PurchaseRequestItem @relation(fields: [sourcePurchaseRequestItemId], references: [id], onDelete: Restrict)

  lineNumber  Int
  itemCode    String?
  description String
  uom         String

  quantityOrdered  Decimal @db.Decimal(12, 3)
  quantityReceived Decimal @default(0) @db.Decimal(12, 3)
  isShortClosed    Boolean @default(false)
  shortClosedQuantity Decimal @default(0) @db.Decimal(12, 3)
  shortClosedReason String? @db.Text
  shortClosedAt     DateTime?
  shortClosedByUserId String?
  shortClosedByUser   User? @relation("PurchaseOrderLineShortClosedByUser", fields: [shortClosedByUserId], references: [id], onDelete: SetNull)
  unitPrice        Decimal @default(0) @db.Decimal(12, 2)
  lineTotal        Decimal @default(0) @db.Decimal(14, 2)
  remarks          String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goodsReceiptLines PurchaseOrderGoodsReceiptLine[]

  @@unique([purchaseOrderId, lineNumber])
  @@unique([purchaseOrderId, sourcePurchaseRequestItemId])
  @@index([sourcePurchaseRequestItemId])
  @@index([shortClosedByUserId])
}

model PurchaseOrderGoodsReceipt {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)

  grpoNumber String
  receivedAt DateTime @db.Date
  remarks    String?  @db.Text

  subtotal  Decimal @default(0) @db.Decimal(14, 2)
  vatAmount Decimal @default(0) @db.Decimal(14, 2)
  discount  Decimal @default(0) @db.Decimal(14, 2)
  grandTotal Decimal @default(0) @db.Decimal(14, 2)

  receivedByUserId String
  receivedByUser   User @relation("PurchaseOrderGoodsReceiptReceivedByUser", fields: [receivedByUserId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines PurchaseOrderGoodsReceiptLine[]

  @@unique([companyId, grpoNumber])
  @@index([purchaseOrderId, receivedAt])
  @@index([receivedByUserId])
}

model PurchaseOrderGoodsReceiptLine {
  id String @id @default(uuid())

  goodsReceiptId String
  goodsReceipt   PurchaseOrderGoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)

  purchaseOrderLineId String
  purchaseOrderLine   PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id], onDelete: Restrict)

  lineNumber Int
  itemCode   String?
  description String
  uom         String

  quantityOrdered           Decimal @db.Decimal(12, 3)
  previouslyReceivedQuantity Decimal @default(0) @db.Decimal(12, 3)
  receivedQuantity          Decimal @db.Decimal(12, 3)
  remainingQuantity         Decimal @default(0) @db.Decimal(12, 3)
  unitPrice                Decimal @default(0) @db.Decimal(12, 2)
  lineTotal                Decimal @default(0) @db.Decimal(14, 2)
  remarks                  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([goodsReceiptId, lineNumber])
  @@index([purchaseOrderLineId])
}

model MaterialRequestServeBatch {
  id String @id @default(uuid())

  materialRequestId String
  materialRequest   MaterialRequest @relation(fields: [materialRequestId], references: [id], onDelete: Cascade)

  poNumber       String
  supplierName   String
  notes          String?  @db.Text
  isFinalServe   Boolean  @default(false)
  servedAt       DateTime @default(now())
  servedByUserId String
  servedByUser   User     @relation("MaterialRequestServeBatchServedByUser", fields: [servedByUserId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items MaterialRequestServeBatchItem[]

  @@index([materialRequestId, servedAt])
  @@index([servedByUserId])
}

model MaterialRequestServeBatchItem {
  id String @id @default(uuid())

  batchId String
  batch   MaterialRequestServeBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  materialRequestItemId String
  materialRequestItem   MaterialRequestItem @relation(fields: [materialRequestItemId], references: [id], onDelete: Restrict)

  quantityServed Decimal @db.Decimal(12, 3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([batchId, materialRequestItemId])
  @@index([materialRequestItemId])
}

model MaterialRequestPosting {
  id String @id @default(uuid())

  materialRequestId String
  materialRequest   MaterialRequest @relation(fields: [materialRequestId], references: [id], onDelete: Cascade)

  postingReference String
  remarks          String?  @db.Text
  postedAt         DateTime @default(now())
  postedByUserId   String
  postedByUser     User     @relation("MaterialRequestPostingPostedByUser", fields: [postedByUserId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([materialRequestId, postedAt])
  @@index([postedByUserId])
}

model MaterialRequestReceivingReport {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  materialRequestId String          @unique
  materialRequest   MaterialRequest @relation(fields: [materialRequestId], references: [id], onDelete: Cascade)

  reportNumber     String
  remarks          String?  @db.Text
  receivedAt       DateTime @default(now())
  receivedByUserId String
  receivedByUser   User     @relation("MaterialRequestReceivingReportReceivedByUser", fields: [receivedByUserId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items MaterialRequestReceivingReportItem[]

  @@unique([companyId, reportNumber])
  @@index([companyId, receivedAt])
  @@index([materialRequestId, receivedAt])
  @@index([receivedByUserId])
}

model MaterialRequestReceivingReportItem {
  id String @id @default(uuid())

  receivingReportId String
  receivingReport   MaterialRequestReceivingReport @relation(fields: [receivingReportId], references: [id], onDelete: Cascade)

  materialRequestItemId String
  materialRequestItem   MaterialRequestItem @relation(fields: [materialRequestItemId], references: [id], onDelete: Restrict)

  lineNumber        Int
  itemCode          String?
  description       String
  uom               String
  requestedQuantity Decimal  @db.Decimal(12, 3)
  receivedQuantity  Decimal  @db.Decimal(12, 3)
  unitPrice         Decimal? @db.Decimal(12, 2)
  lineTotal         Decimal? @db.Decimal(14, 2)
  remarks           String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([receivingReportId, materialRequestItemId])
  @@index([receivingReportId, lineNumber])
  @@index([materialRequestItemId])
}
